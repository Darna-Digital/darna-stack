  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.3.0",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "wrangler": "4.87.0"
