# Copy to `.dev.vars` (gitignored). Wrangler reads this for `wrangler dev`.
# For local Node dev (`pnpm dev`), copy the same values into `.env` (also gitignored)
# or export them in your shell.
#
# Production: set via `wrangler secret put WORKOS_CLIENT_ID` (etc.) — never in wrangler.jsonc.

# WorkOS — required by adminMiddleware to verify access tokens against
# https://api.workos.com/sso/jwks/<WORKOS_CLIENT_ID>
WORKOS_CLIENT_ID=

# Optional — only needed if you call the WorkOS REST API from this backend
# (e.g. listing users, creating organizations). Not required for token verification.
# WORKOS_API_KEY=

# OpenTelemetry → Grafana Cloud. Both must be set for spans to export;
# otherwise TracingLayer is a no-op (Effect.withSpan calls still run, just
# don't ship anywhere).
#
# Both values come from your Grafana Cloud OTLP integration page
# (Connections → Add → OpenTelemetry). Copy them verbatim — the auth header
# is the full "Basic <base64>" string Grafana shows; we don't split it.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-north-0.grafana.net/otlp
# GRAFANA_OTEL_AUTH_HEADER=Basic <long base64>
#
# Optional — tags every span with `deployment.environment`. Defaults to "local".
# OTEL_DEPLOYMENT_ENV=local
