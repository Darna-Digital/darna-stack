{
  "name": "@darna/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    },
    "./schemas/todo": {
      "types": "./src/features/todo/todo.model.ts",
      "default": "./src/features/todo/todo.model.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev:cf": "wrangler dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@hono/node-server": "^2.0.1",
    "@scalar/hono-api-reference": "^0.10.13",
    "effect": "^3.21.2",
    "hono": "^4.12.16",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.87.0"
  }
}
