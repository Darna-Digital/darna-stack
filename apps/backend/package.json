{
  "name": "@darna/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    },
    "./schemas/todo": {
      "types": "./src/features/todo/todo.model.ts",
      "default": "./src/features/todo/todo.model.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev:cf": "wrangler dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "tsx --env-file-if-exists=.env scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@hono/node-server": "^2.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.216.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@scalar/hono-api-reference": "^0.10.13",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@darna/lint": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.87.0"
  }
}
