{
  "name": "@darna/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote --env-file=.env --port=4000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "tsx --env-file-if-exists=.env src/scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@microlabs/otel-cf-workers": "1.0.0-rc.52",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@scalar/hono-api-reference": "^0.10.16",
    "aws4fetch": "^1.0.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@darna/lint": "workspace:*",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "4.92.0"
  }
}
