{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "darna-backend",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["grafana-logs"],
      "head_sampling_rate": 1
    }
  },
  "routes": [{ "pattern": "darna-stack-backend.darnadigital.com", "custom_domain": true }],
  "hyperdrive": [{ "binding": "HYPERDRIVE", "id": "44ef9aa003384c76965ec29d2624e0d9" }],
  "r2_buckets": [{ "binding": "FILES_BUCKET", "bucket_name": "darna-stack" }],
  "vars": { "OTEL_DEPLOYMENT_ENV": "production" },
  "env": {
    "staging": {
      "name": "darna-backend-staging",
      "routes": [
        { "pattern": "staging-darna-stack-backend.darnadigital.com", "custom_domain": true }
      ],
      "observability": {
        "enabled": true,
        "logs": {
          "enabled": true,
          "destinations": ["grafana-logs"],
          "head_sampling_rate": 1
        }
      },
      "r2_buckets": [{ "binding": "FILES_BUCKET", "bucket_name": "darna-stack-staging" }],
      "vars": { "OTEL_DEPLOYMENT_ENV": "staging" }
    }
  }
}
