# Copy to `.env` (gitignored). Used by:
#   - `pnpm dev` (wrangler dev --env-file=.env): values are exposed both as
#     CLI env vars (so wrangler reads CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_*)
#     and as Worker bindings (so the Worker sees them on the `env` arg).
#   - `pnpm db:migrate` and `drizzle-kit` commands (read DATABASE_URL).
#
# Production: set via `wrangler secret put <NAME>` (and again with `--env staging`).
# Never put production secrets in this file.

# WorkOS — required by adminMiddleware to verify access tokens against
# https://api.workos.com/sso/jwks/<WORKOS_CLIENT_ID>
WORKOS_CLIENT_ID=

# Optional — only needed if you call the WorkOS REST API from this backend
# (e.g. listing users, creating organizations). Not required for token verification.
# WORKOS_API_KEY=

# OpenTelemetry → Grafana Cloud. Both are required for traces to export.
# Values come from your Grafana Cloud OTLP integration page (Connections →
# Add → OpenTelemetry). Copy them verbatim — the auth header is the full
# "Basic <base64>" string Grafana shows; we don't split it.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-north-0.grafana.net/otlp
# GRAFANA_OTEL_AUTH_HEADER=Basic <long base64>

# Tags every span with `resource.service.namespace`. Defaults to "production"
# in prod (set via wrangler.jsonc `vars`). For local dev, override to "local".
# OTEL_DEPLOYMENT_ENV=local

# Postgres URL used by drizzle-kit and the migrate script.
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Local Hyperdrive override — wrangler points the HYPERDRIVE binding at this
# Postgres URL during `wrangler dev`. Same value as DATABASE_URL works for solo dev.
# CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://user:pass@host:5432/db?sslmode=require
