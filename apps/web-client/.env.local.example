# Copy to `.env.local` (gitignored — Next.js loads it automatically in dev).
# In CI/production, NEXT_PUBLIC_* vars are baked at build time via the
# `deploy-web-client` job in `.github/workflows/deploy.yml`, sourced from
# environment-scoped GitHub `vars`.

# Base URL of @darna/backend used by the in-browser oRPC/openapi-fetch client.
# Local dev:  http://localhost:4000
# Staging:    https://staging-darna-stack-backend.darnadigital.com
# Production: https://darna-stack-backend.darnadigital.com
NEXT_PUBLIC_API_URL=http://localhost:4000
