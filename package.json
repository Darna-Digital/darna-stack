{
  "name": "darna-stack",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @darna/backend dev",
    "dev:admin": "pnpm --filter @darna/admin dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "deploy": "pnpm --filter @darna/backend run deploy && pnpm --filter @darna/admin run deploy",
    "deploy:backend": "pnpm --filter @darna/backend run deploy",
    "deploy:admin": "pnpm --filter @darna/admin run deploy"
  },
  "engines": {
    "node": ">=22"
  }
}
